# =============================================================================
# Supabase Self-Hosted - Umgebungsvariablen
# =============================================================================
# Diese Datei wird automatisch von cloud-init generiert.
# Für lokale Tests: Kopiere nach .env und fülle die Werte aus.
# =============================================================================

# =============================================================================
# Allgemein
# =============================================================================
DOMAIN=supabase.example.com
SITE_URL=https://supabase.example.com

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-super-secure-postgres-password

# Connection Pooling
POOLER_DEFAULT_POOL_SIZE=15
POOLER_MAX_CLIENT_CONN=100

# =============================================================================
# JWT / Auth
# =============================================================================
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
JWT_EXPIRY=3600
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Dashboard / Studio
# =============================================================================
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-dashboard-password
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

# =============================================================================
# API Gateway (Kong)
# =============================================================================
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# =============================================================================
# Let's Encrypt (ACME)
# =============================================================================
ACME_EMAIL=admin@example.com
ACME_DOMAIN=supabase.example.com

# =============================================================================
# GoTrue (Auth)
# =============================================================================
GOTRUE_JWT_SECRET=${JWT_SECRET}
GOTRUE_JWT_EXP=${JWT_EXPIRY}
GOTRUE_DB_DRIVER=postgres
GOTRUE_API_HOST=0.0.0.0
GOTRUE_API_PORT=9999
GOTRUE_SITE_URL=${SITE_URL}
GOTRUE_URI_ALLOW_LIST=
GOTRUE_DISABLE_SIGNUP=false

# External OAuth Provider (optional)
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=false

# SMTP Einstellungen (optional)
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=
GOTRUE_SMTP_SENDER_NAME=Supabase

# =============================================================================
# PostgREST
# =============================================================================
PGRST_DB_URI=postgres://authenticator:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
PGRST_DB_SCHEMA=public,storage,graphql_public
PGRST_DB_ANON_ROLE=anon
PGRST_JWT_SECRET=${JWT_SECRET}

# =============================================================================
# Realtime
# =============================================================================
REALTIME_DB_HOST=${POSTGRES_HOST}
REALTIME_DB_PORT=${POSTGRES_PORT}
REALTIME_DB_NAME=${POSTGRES_DB}
REALTIME_DB_USER=supabase_admin
REALTIME_DB_PASSWORD=${POSTGRES_PASSWORD}

# =============================================================================
# Storage
# =============================================================================
STORAGE_BACKEND=s3

# S3 Konfiguration (Hetzner Object Storage)
S3_BUCKET=supabase-storage
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=eu-central-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_FORCE_PATH_STYLE=true

# Legacy Storage Variablen
GLOBAL_S3_BUCKET=${S3_BUCKET}
GLOBAL_S3_ENDPOINT=${S3_ENDPOINT}
AWS_ACCESS_KEY_ID=${S3_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${S3_SECRET_KEY}
REGION=${S3_REGION}
STORAGE_S3_FORCE_PATH_STYLE=${S3_FORCE_PATH_STYLE}

# =============================================================================
# Analytics (Logflare)
# =============================================================================
LOGFLARE_API_KEY=your-logflare-api-key
LOGFLARE_URL=http://analytics:4000

# =============================================================================
# Weitere Secrets
# =============================================================================
SECRET_KEY_BASE=your-secret-key-base
VAULT_ENC_KEY=your-vault-encryption-key

# =============================================================================
# Backup (docker-volume-backup)
# =============================================================================
BACKUP_CRON_EXPRESSION=0 3 * * *
BACKUP_RETENTION_DAYS=14
S3_BACKUP_BUCKET=supabase-backups

# Notifications (optional) - Shoutrrr Format
# Telegram: telegram://BOT_TOKEN@telegram?chats=CHAT_ID
# Slack: slack://hook:WEBHOOK_ID@webhook
# Discord: discord://TOKEN@WEBHOOK_ID
NOTIFICATION_URLS=

# =============================================================================
# Monitoring
# =============================================================================
# Uptime Kuma Port
UPTIME_KUMA_PORT=3001

# Portainer Port
PORTAINER_PORT=9443

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true
